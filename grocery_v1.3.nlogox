<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.2" snapToGrid="true">
  <code><![CDATA[;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Grocery Store Queuing Model – Full Logic with Jockeying
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

breed [ customers customer ]
breed [ cashiers cashier ]

globals [
  ticks-per-second
  sim-duration-ticks
  arrival-prob-per-tick

  ;; Statistics
  total-wait-time
  wait-times-list
  num-served
  cumulative-queue-length
  queue-length-samples
  total-busy-time
  avg-wait-time
  p95-wait-time
  avg-queue-length
  throughput
  utilization

  ;; Peak time
  base-arrival-prob-per-tick
  current-arrival-prob-per-tick

  ;; Shift system
  sim-error-msg
  shift-arrival-rates           ;; list: e.g. [60 30]
  shift-avg-service-times       ;; list: e.g. [300 200]
  current-shift                 ;; current shift index (0-based)
  current-shift-start-tick      ;; when the current shift started

  ;; Former slider variables (now set via command center)
  num-cash-counters
  num-card-counters
  num-express-counters
  num-self-checkout-counters
  arrival-rate
  avg-service-time
  prob-cash
  service-variability
  cash-payment-mean
  cash-payment-sd
  card-payment-mean
  card-payment-sd
  peak1-start-hour
  peak1-end-hour
  peak1-multiplier
  peak2-start-hour
  peak2-end-hour
  peak2-multiplier
  self-checkout-scan-time
  self-checkout-payment-time
  num-rounds
  operating-hours
  num-shifts

  ;; Per-shift counter lists (replace shift-counter-multipliers)
  shift-num-cash             ;; list: e.g. [3 2]
  shift-num-card             ;; list: e.g. [3 2]
  shift-num-express          ;; list: e.g. [1 1]
  shift-num-self-checkout    ;; list: e.g. [2 1]
]

customers-own [
  arrival-tick
  service-start-tick
  items-in-hand
  payment-method         ;; "cash" or "card"
  my-cashier             ;; Which cashier this customer is queuing for
  queue-position         ;; Position in the queue
  being-served?          ;; True while being processed at counter
]

cashiers-own [
  busy?
  remaining-service-time
  express?               ;; True if the cashier is an express lane
  cashier-type           ;; "cash", "card", "express", or "self-checkout"
  original-type          ;; Stores original type for reverting temporary conversions
  active?                ;; True if this counter is active in the current shift
  serving-customer       ;; The customer currently being served (nobody if idle)
]

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; SETUP
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to setup
  clear-ticks
  clear-turtles
  clear-patches
  clear-drawing
  clear-all-plots
  clear-output
  reset-ticks

  ;; Defaults for former-slider variables (only if not set via command center)
  if num-cash-counters = 0 [ set num-cash-counters 3 ]
  if num-card-counters = 0 [ set num-card-counters 3 ]
  if num-express-counters = 0 [ set num-express-counters 1 ]
  if num-self-checkout-counters = 0 [ set num-self-checkout-counters 2 ]
  if arrival-rate = 0 [ set arrival-rate 60 ]
  if avg-service-time = 0 [ set avg-service-time 300 ]
  if prob-cash = 0 [ set prob-cash 0.5 ]
  if service-variability = 0 [ set service-variability 0.2 ]
  if cash-payment-mean = 0 [ set cash-payment-mean 11 ]
  if cash-payment-sd = 0 [ set cash-payment-sd 3 ]
  if card-payment-mean = 0 [ set card-payment-mean 6 ]
  if card-payment-sd = 0 [ set card-payment-sd 2 ]
  if self-checkout-scan-time = 0 [ set self-checkout-scan-time 5 ]
  if self-checkout-payment-time = 0 [ set self-checkout-payment-time 8 ]
  if num-rounds = 0 [ set num-rounds 1 ]
  if operating-hours = 0 [ set operating-hours 16 ]
  if num-shifts = 0 [ set num-shifts 1 ]
  ;; Peak defaults: 0 is valid (disabled), so no defaults needed

  ;; Initialize shift lists with defaults if not set
  if not is-list? shift-arrival-rates [ set shift-arrival-rates (list arrival-rate) ]
  if not is-list? shift-avg-service-times [ set shift-avg-service-times (list avg-service-time) ]
  if not is-list? shift-num-cash [ set shift-num-cash (list num-cash-counters) ]
  if not is-list? shift-num-card [ set shift-num-card (list num-card-counters) ]
  if not is-list? shift-num-express [ set shift-num-express (list num-express-counters) ]
  if not is-list? shift-num-self-checkout [ set shift-num-self-checkout (list num-self-checkout-counters) ]

  ;; Compute MAX counters across all shifts (create them all, hide extras later)
  set num-cash-counters reduce [ [a b] -> max list a b ] shift-num-cash
  set num-card-counters reduce [ [a b] -> max list a b ] shift-num-card
  set num-express-counters reduce [ [a b] -> max list a b ] shift-num-express
  set num-self-checkout-counters reduce [ [a b] -> max list a b ] shift-num-self-checkout

  set ticks-per-second 1
  set sim-duration-ticks (num-rounds * operating-hours * 3600)
  set base-arrival-prob-per-tick (arrival-rate / 3600)
  set current-arrival-prob-per-tick base-arrival-prob-per-tick

  ;; Initialize shift system
  set sim-error-msg ""
  set current-shift 0
  set current-shift-start-tick 0

  ;; Initialize statistics
  set wait-times-list []
  set total-wait-time 0
  set num-served 0
  set cumulative-queue-length 0
  set queue-length-samples 0
  set total-busy-time 0

  ;; Create cashiers at specific locations
  ask patches [ set pcolor black ]

  let total-counters (num-cash-counters + num-card-counters + num-express-counters + num-self-checkout-counters)
  let counter-spacing floor (world-width / (total-counters + 1))
  let counter-y min-pycor + 2

  let i 0

  ;; Create cash counters (Green)
  repeat num-cash-counters [
    let counter-x (min-pxcor + counter-spacing * (i + 1))
    ask patch counter-x counter-y [
      sprout-cashiers 1 [
        set shape "person"
        set color green
        set size 1.5
        set busy? false
        set remaining-service-time 0
        set express? false
        set cashier-type "cash"
        set original-type "cash"
        set active? true
        set serving-customer nobody
      ]
    ]
    set i i + 1
  ]

  ;; Create card counters (Orange)
  repeat num-card-counters [
    let counter-x (min-pxcor + counter-spacing * (i + 1))
    ask patch counter-x counter-y [
      sprout-cashiers 1 [
        set shape "person"
        set color orange
        set size 1.5
        set busy? false
        set remaining-service-time 0
        set express? false
        set cashier-type "card"
        set original-type "card"
        set active? true
        set serving-customer nobody
      ]
    ]
    set i i + 1
  ]

  ;; Create express counters (Blue)
  repeat num-express-counters [
    let counter-x (min-pxcor + counter-spacing * (i + 1))
    ask patch counter-x counter-y [
      sprout-cashiers 1 [
        set shape "person"
        set color blue
        set size 1.5
        set busy? false
        set remaining-service-time 0
        set express? true
        set cashier-type "express"
        set original-type "express"
        set active? true
        set serving-customer nobody
      ]
    ]
    set i i + 1
  ]

  ;; Create self-checkout counters (Magenta)
  repeat num-self-checkout-counters [
    let counter-x (min-pxcor + counter-spacing * (i + 1))
    ask patch counter-x counter-y [
      sprout-cashiers 1 [
        set shape "person"
        set color magenta
        set size 1.5
        set busy? false
        set remaining-service-time 0
        set express? false
        set cashier-type "self-checkout"
        set original-type "self-checkout"
        set active? true
        set serving-customer nobody
      ]
    ]
    set i i + 1
  ]

  ;; Apply initial shift (shift 0) visibility
  apply-shift-changes
  update-shift-display
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; GO
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to go
  ;; Stop conditions
  let total-queue-length count customers with [not being-served?]
  if total-queue-length > 50 [
    set sim-error-msg "All Cashiers Overloaded - Please extend number of Cashiers"
    stop
  ]

  if ticks >= sim-duration-ticks [
    finalize-stats
    stop
  ]

  validate-peak-periods

  update-shift
  update-arrival-rate-by-time

  generate-arrivals
  
  ;; --- Dynamic Logic ---
  check-express-overflow    ;; Global rule: Redirect new express users if clogged
  check-convert-to-express  ;; Global rule: Open new express lane if needed
  balance-queues            ;; NEW: Individual customers decide to switch lines (Jockeying)
  ;; ---------------------

  update-customer-positions
  ask cashiers [ process-service ]
  
  update-queue-stats
  compute-live-stats
  
  tick
end


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; PEAK TIME
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
to update-arrival-rate-by-time
  ;; Current hour within operating cycle (repeats each round)
  let seconds-per-cycle (operating-hours * 3600)
  let cycle-tick (ticks mod seconds-per-cycle)
  let current-hour (cycle-tick / 3600)

  ;; Default = normal arrival rate
  set current-arrival-prob-per-tick base-arrival-prob-per-tick

  ;; Peak period 1 — gradual sine ramp
  if peak1-multiplier > 0 and peak1-end-hour > peak1-start-hour [
    if (current-hour >= peak1-start-hour) and (current-hour < peak1-end-hour) [
      let progress (current-hour - peak1-start-hour) / (peak1-end-hour - peak1-start-hour)
      let factor 1 + (peak1-multiplier - 1) * sin (progress * 180)
      set current-arrival-prob-per-tick (base-arrival-prob-per-tick * factor)
    ]
  ]

  ;; Peak period 2 — gradual sine ramp
  if peak2-multiplier > 0 and peak2-end-hour > peak2-start-hour [
    if (current-hour >= peak2-start-hour) and (current-hour < peak2-end-hour) [
      let progress (current-hour - peak2-start-hour) / (peak2-end-hour - peak2-start-hour)
      let factor 1 + (peak2-multiplier - 1) * sin (progress * 180)
      set current-arrival-prob-per-tick (base-arrival-prob-per-tick * factor)
    ]
  ]

  ;; Safety cap (probability can't exceed 1)
  if current-arrival-prob-per-tick > 1 [
    set current-arrival-prob-per-tick 1
  ]
end


to validate-peak-periods
  ;; Skip validation if peaks are disabled (all zeros)
  let peak1-disabled (peak1-start-hour = 0 and peak1-end-hour = 0 and peak1-multiplier = 0)
  let peak2-disabled (peak2-start-hour = 0 and peak2-end-hour = 0 and peak2-multiplier = 0)

  ;; end must be greater than start
  if not peak1-disabled [
    if peak1-end-hour <= peak1-start-hour [
      set sim-error-msg "Invalid Peak 1: end hour must be greater than start hour."
      stop
    ]
    if peak1-end-hour > operating-hours [
      set sim-error-msg "Invalid Peak 1: end hour exceeds operating hours."
      stop
    ]
  ]

  if not peak2-disabled [
    if peak2-end-hour <= peak2-start-hour [
      set sim-error-msg "Invalid Peak 2: end hour must be greater than start hour."
      stop
    ]
    if peak2-end-hour > operating-hours [
      set sim-error-msg "Invalid Peak 2: end hour exceeds operating hours."
      stop
    ]
  ]

  ;; Peaks must NOT overlap
  if not peak1-disabled and not peak2-disabled [
    if (peak1-start-hour < peak2-end-hour) and (peak2-start-hour < peak1-end-hour) [
      set sim-error-msg "Invalid Peaks: Peak 1 and Peak 2 are overlapping."
      stop
    ]
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; SHIFT MANAGEMENT
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to update-shift
  if num-shifts <= 1 [ stop ]
  let seconds-per-cycle (operating-hours * 3600)
  let current-cycle-tick (ticks mod seconds-per-cycle)
  let shift-duration-ticks (seconds-per-cycle / num-shifts)
  let new-shift (floor (current-cycle-tick / shift-duration-ticks))
  if new-shift >= num-shifts [ set new-shift (num-shifts - 1) ]
  if new-shift != current-shift [
    set current-shift new-shift
    set current-shift-start-tick ticks
    apply-shift-changes
  ]
end

to apply-shift-changes
  ;; 1. Update arrival rate for this shift
  if is-list? shift-arrival-rates and current-shift < length shift-arrival-rates [
    let shift-rate item current-shift shift-arrival-rates
    set base-arrival-prob-per-tick (shift-rate / 3600)
    set current-arrival-prob-per-tick base-arrival-prob-per-tick
  ]
  ;; 2. Update avg service time for this shift
  if is-list? shift-avg-service-times and current-shift < length shift-avg-service-times [
    set avg-service-time item current-shift shift-avg-service-times
  ]
  ;; 3. Adjust cashier visibility per type
  if is-list? shift-num-cash and current-shift < length shift-num-cash [
    adjust-cashier-visibility "cash" item current-shift shift-num-cash
  ]
  if is-list? shift-num-card and current-shift < length shift-num-card [
    adjust-cashier-visibility "card" item current-shift shift-num-card
  ]
  if is-list? shift-num-express and current-shift < length shift-num-express [
    adjust-cashier-visibility "express" item current-shift shift-num-express
  ]
  if is-list? shift-num-self-checkout and current-shift < length shift-num-self-checkout [
    adjust-cashier-visibility "self-checkout" item current-shift shift-num-self-checkout
  ]
  update-shift-display
end

to adjust-cashier-visibility [ lane-type target-count ]
  let all-of-type cashiers with [original-type = lane-type]
  let active-of-type all-of-type with [active?]
  let active-count count active-of-type

  ;; Close excess lanes
  if active-count > target-count [
    let to-close active-count - target-count
    let closeable active-of-type with [not busy?]
    ask n-of (min list to-close count closeable) closeable [
      ;; Reassign customers from this cashier
      let me self
      ask customers with [my-cashier = me] [
        let open-cashiers cashiers with [active? and self != me]
        if any? open-cashiers [
          set my-cashier min-one-of open-cashiers [count customers with [my-cashier = myself and not being-served?]]
        ]
      ]
      set active? false
      set color black
    ]
  ]
  ;; Open more lanes
  if active-count < target-count [
    let to-open target-count - active-count
    let closed-of-type all-of-type with [not active?]
    if any? closed-of-type [
      ask n-of (min list to-open count closed-of-type) closed-of-type [
        set active? true
        restore-cashier-color
      ]
    ]
  ]
end

to restore-cashier-color
  if original-type = "cash" [ set color green ]
  if original-type = "card" [ set color orange ]
  if original-type = "express" [ set color blue ]
  if original-type = "self-checkout" [ set color magenta ]
end

to update-shift-display
  ;; Show shift info at top-left corner of the world
  let shift-dur-min (operating-hours * 60 / num-shifts)
  let s-start floor (current-shift * shift-dur-min)
  let s-end floor ((current-shift + 1) * shift-dur-min)
  let s-start-h floor (s-start / 60)
  let s-start-m (s-start mod 60)
  let s-end-h floor (s-end / 60)
  let s-end-m (s-end mod 60)

  ;; Count active counters per type
  let nc count cashiers with [original-type = "cash" and active?]
  let nd count cashiers with [original-type = "card" and active?]
  let ne count cashiers with [original-type = "express" and active?]
  let nsc count cashiers with [original-type = "self-checkout" and active?]

  ;; Line 1: Shift number + time range
  ask patch (min-pxcor + 6) (max-pycor - 1) [
    set plabel (word "Shift " (current-shift + 1) "/" num-shifts
      "  (" s-start-h ":" (ifelse-value (s-start-m < 10) ["0"] [""]) s-start-m
      " - " s-end-h ":" (ifelse-value (s-end-m < 10) ["0"] [""]) s-end-m ")")
    set plabel-color white
  ]

  ;; Line 2: Active counter counts
  ask patch (min-pxcor + 6) (max-pycor - 2) [
    set plabel (word nc " Cash | " nd " Card | " ne " Express | " nsc " Self-checkout")
    set plabel-color 9.9
  ]
end


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; ARRIVALS
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to generate-arrivals
  if (random-float 1.0 < current-arrival-prob-per-tick) [

    create-customers 1 [
      set shape "person"
      set color white
      set size 1
      set arrival-tick ticks
      set service-start-tick -1
      
      ;; 1. Determine attributes
      set items-in-hand (1 + random 15)
      set payment-method (ifelse-value (random-float 1 < prob-cash) ["cash"] ["card"])
      
      ;; !!! FIX: Capture payment method in a local variable for comparison !!!
      let my-pay payment-method 
      
      ;; 2. Initial Cashier Selection
      let eligible-cashiers no-turtles

      ;; Build self-checkout set (card customers only)
      let self-checkout-set no-turtles
      if my-pay = "card" [
        set self-checkout-set cashiers with [cashier-type = "self-checkout" and active?]
      ]

      ifelse items-in-hand < 5 [
        ;; Express Customer: Can use Express OR Regular matching payment
        let express-set cashiers with [cashier-type = "express" and active?]

        ;; FIX APPLIED HERE: Use 'my-pay' instead of 'payment-method'
        let regular-set cashiers with [cashier-type = my-pay and active?]

        ;; Prefer express, but if express is full (>10), consider regular + self-checkout
        let express-load sum [count customers with [my-cashier = myself and not being-served?]] of express-set

        ifelse (express-load > (10 * count express-set)) [
           set eligible-cashiers (turtle-set express-set regular-set self-checkout-set)
        ] [
           set eligible-cashiers express-set
        ]

        ;; Fallback if no express lanes exist
        if not any? eligible-cashiers [ set eligible-cashiers (turtle-set regular-set self-checkout-set) ]

      ] [
        ;; Regular Customer: MUST use Regular matching payment OR self-checkout (if card)
        ;; FIX APPLIED HERE: Use 'my-pay' instead of 'payment-method'
        set eligible-cashiers (turtle-set cashiers with [cashier-type = my-pay and active?] self-checkout-set)
      ]
      
      ;; 3. Assign to shortest eligible queue
      ifelse any? eligible-cashiers [
        set my-cashier min-one-of eligible-cashiers [count customers with [my-cashier = myself and not being-served?]]
      ] [
        ;; Emergency fallback (go to any cashier matching type to avoid crash)
        set my-cashier one-of cashiers with [cashier-type = my-pay and active?]
        if my-cashier = nobody [
          ifelse my-pay = "cash" [
            set my-cashier one-of cashiers with [cashier-type != "self-checkout" and active?]
          ] [
            set my-cashier one-of cashiers with [active?]
          ]
        ]
      ]
      
      ;; 4. Set Position
      if my-cashier != nobody [
        setxy ([xcor] of my-cashier) max-pycor
      ]
      set queue-position 0
      set being-served? false
    ]
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; QUEUE MANAGEMENT & JOCKEYING (NEW)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to balance-queues
  ;; Customers look around and switch lines if a neighbor is much faster
  ;; We only let customers switch if they haven't started service yet
  
  ask customers with [not being-served? and service-start-tick = -1] [
    let me self
    let my-current-cashier my-cashier
    
    if my-current-cashier != nobody [
      ;; Calculate my current queue length
      let my-queue-len count customers with [my-cashier = my-current-cashier and not being-served?]
      
      ;; Identify potential targets based on STRICT rules
      let eligible-targets no-turtles
      
      ifelse items-in-hand < 5 [
        ;; Express user: Can switch to Express, compatible Regular, or self-checkout (if card)
        ifelse payment-method = "card" [
          set eligible-targets cashiers with [
            (cashier-type = "express" or cashier-type = "card" or cashier-type = "self-checkout") and active?
          ]
        ] [
          set eligible-targets cashiers with [
            (cashier-type = "express" or cashier-type = "cash") and active?
          ]
        ]
      ] [
        ;; Regular user: Can switch to compatible Regular or self-checkout (if card)
        ifelse payment-method = "card" [
          set eligible-targets cashiers with [
            (cashier-type = "card" or cashier-type = "self-checkout") and active?
          ]
        ] [
          set eligible-targets cashiers with [
            cashier-type = "cash" and active?
          ]
        ]
      ]
      
      ;; Filter out current cashier
      set eligible-targets eligible-targets with [self != my-current-cashier]
      
      if any? eligible-targets [
        ;; Find the best option
        let best-target min-one-of eligible-targets [count customers with [my-cashier = myself and not being-served?]]
        let best-queue-len count customers with [my-cashier = best-target and not being-served?]
        
        ;; THE DECISION: Switch only if difference > 2
        ;; (Prevents thrashing/jumping back and forth for minor gains)
        if (my-queue-len > (best-queue-len + 2)) [
          set my-cashier best-target
          ;; Visual update happens in update-customer-positions
        ]
      ]
    ]
  ]
end

to check-express-overflow
  ;; Existing logic: If express is totally swamped (>20), force flush some to regular
  let express-cashiers-set cashiers with [cashier-type = "express"]
  if any? express-cashiers-set [
    let express-queue-length sum [count customers with [my-cashier = myself and not being-served?]] of express-cashiers-set
    if express-queue-length > 20 [
      ask customers with [[cashier-type] of my-cashier = "express" and items-in-hand < 5] [
        ;; Re-evaluate best cashier (balance-queues will handle the actual move)
        ;; This essentially "wakes them up" to check options immediately
      ]
    ]
  ]
end

to check-convert-to-express
  ;; If express queue > 15 and there are idle regular cashiers, convert one to express
  let express-cashiers-set cashiers with [cashier-type = "express"]
  if any? express-cashiers-set [
    let express-queue-length sum [count customers with [my-cashier = myself and not being-served?]] of express-cashiers-set

    if express-queue-length > 15 [
      ;; Find idle regular cashiers
      let idle-regular one-of cashiers with [cashier-type != "express" and cashier-type != "self-checkout" and not busy? and active?]
      if idle-regular != nobody [
        ask idle-regular [
          set cashier-type "express"
          set color blue
        ]
        ;; We don't force move customers here; 
        ;; balance-queues will naturally move express customers to this new empty lane next tick.
      ]
    ]
  ]
  
  ;; Revert temporary express lanes
  ask cashiers with [cashier-type = "express" and original-type != "express"] [
    let my-queue-length count customers with [my-cashier = myself and not being-served?]
    if my-queue-length = 0 and not busy? [
      set cashier-type original-type
      if cashier-type = "cash" [ set color green ]
      if cashier-type = "card" [ set color orange ]
    ]
  ]
end

to update-customer-positions
  ask cashiers with [active?] [
    let my-counter-x xcor
    let my-counter-y ycor

    ;; Position the being-served customer next to the cashier
    if serving-customer != nobody [
      ask serving-customer [
        setxy my-counter-x (my-counter-y + 1.5)
      ]
    ]

    ;; Queue only waiting customers (not being served)
    let waiting-customers customers with [my-cashier = myself and not being-served?]

    ;; Sort by arrival time (FIFO visual)
    let sorted-customers sort-on [arrival-tick] waiting-customers

    let pos 0
    foreach sorted-customers [ c ->
      ask c [
        set queue-position pos
        ;; Position customers in a line above the cashier
        let target-x my-counter-x
        let target-y my-counter-y + 3 + pos * 1.5 ;; Tighter spacing

        ;; Move towards target position smoothly
        facexy target-x target-y
        if distance patch target-x target-y > 0.3 [
          fd 0.5 ;; Faster movement for responsiveness
        ]

        ;; Color code by payment method
        ifelse payment-method = "cash" [ set color white ] [ set color yellow ]
      ]
      set pos pos + 1
    ]
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; SERVICE LOGIC
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to-report sample-payment-time [ pay ]
  if pay = "cash" [
    let t round random-normal cash-payment-mean cash-payment-sd
    if t < 1 [ set t 1 ]
    report t
  ]
  if pay = "card" [
    let t round random-normal card-payment-mean card-payment-sd
    if t < 1 [ set t 1 ]
    report t
  ]
  report 0
end

to-report sample-self-checkout-service-time [ num-items ]
  let scan-time num-items * self-checkout-scan-time
  let total scan-time + self-checkout-payment-time
  if total < 1 [ set total 1 ]
  report round total
end

to process-service
  if not active? [ stop ]
  ;; 1. Handle Busy State
  if busy? [
    set remaining-service-time remaining-service-time - 1
    set total-busy-time total-busy-time + 1

    if remaining-service-time <= 0 [
      set busy? false
      ;; Remove the served customer
      if serving-customer != nobody [
        ask serving-customer [ die ]
        set serving-customer nobody
      ]
      ;; Clear busy indicator on patch below
      ask patch xcor (ycor - 1) [ set pcolor black ]
    ]
  ]

  ;; 2. Handle Idle State (Look for customers)
  if not busy? [
    let targets no-turtles
    
    ;; Strict filtering of who this cashier can serve
    if cashier-type = "express" [
      set targets customers with [not being-served? and items-in-hand < 5 and my-cashier = myself]
    ]
    if cashier-type = "cash" [
      set targets customers with [not being-served? and items-in-hand >= 5 and payment-method = "cash" and my-cashier = myself]
      ;; Optional: Also help Express Overflow (items < 5) if they queued here
      set targets (turtle-set targets customers with [not being-served? and items-in-hand < 5 and payment-method = "cash" and my-cashier = myself])
    ]
    if cashier-type = "card" [
      set targets customers with [not being-served? and items-in-hand >= 5 and payment-method = "card" and my-cashier = myself]
       ;; Optional: Also help Express Overflow (items < 5) if they queued here
      set targets (turtle-set targets customers with [not being-served? and items-in-hand < 5 and payment-method = "card" and my-cashier = myself])
    ]
    if cashier-type = "self-checkout" [
      set targets customers with [not being-served? and payment-method = "card" and my-cashier = myself]
    ]

    if any? targets [
      ;; Serve the one who arrived first (FIFO)
      let c min-one-of targets [ arrival-tick ]

      let pay [payment-method] of c
      let num-items [items-in-hand] of c

      ask c [
        set service-start-tick ticks
        let wait-time (service-start-tick - arrival-tick)
        set total-wait-time total-wait-time + wait-time
        set wait-times-list lput wait-time wait-times-list
        set being-served? true
      ]

      set busy? true
      set serving-customer c

      ;; Calculate Time
      ifelse cashier-type = "express" [
        set remaining-service-time 60
      ] [
        ifelse cashier-type = "self-checkout" [
          set remaining-service-time sample-self-checkout-service-time num-items
        ] [
          set remaining-service-time sample-service-time-with-items num-items
          set remaining-service-time remaining-service-time + sample-payment-time pay
        ]
      ]
      ;; Show red busy indicator on patch below cashier
      ask patch xcor (ycor - 1) [ set pcolor red ]
      set num-served num-served + 1
    ]
  ]   
end

to-report sample-service-time-with-items [ num-items ]
  let base-time avg-service-time
  let time-per-item 3
  let item-time num-items * time-per-item
  let mean-service base-time + item-time
  let std (service-variability * mean-service)
  let s mean-service
  if std > 0 [ set s random-normal mean-service std ]
  if s < 1 [ set s 1 ]
  report round s
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; STATISTICS
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to update-queue-stats
  set cumulative-queue-length cumulative-queue-length + count customers with [not being-served?]
  set queue-length-samples queue-length-samples + 1
end

to compute-live-stats
  if num-served > 0 [ set avg-wait-time total-wait-time / num-served ]
  if queue-length-samples > 0 [ set avg-queue-length cumulative-queue-length / queue-length-samples ]
  if ticks > 0 [
    set throughput (num-served / (ticks / 60))
    let active-cashier-count count cashiers with [active?]
    if active-cashier-count > 0 [
      let total-available-time (active-cashier-count * ticks)
      set utilization total-busy-time / total-available-time
    ]
  ]
  if length wait-times-list > 0 [ set p95-wait-time percentile wait-times-list 95 ]
end

to-report percentile [ values p ]
  if empty? values [ report 0 ]
  let sorted sort values
  let n length sorted
  let rank (p / 100) * (n - 1)
  let lower floor rank
  let upper ceiling rank
  ifelse lower = upper 
    [ report item lower sorted ]
    [ let weight rank - lower
      report (item lower sorted) + weight * ((item upper sorted) - (item lower sorted)) ]
end

to finalize-stats
  compute-live-stats
end]]></code>
