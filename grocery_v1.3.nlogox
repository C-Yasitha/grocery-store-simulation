    <plot x="1025" autoPlotX="true" yMax="10.0" autoPlotY="true" y="20" xMin="0.0" height="175" legend="false" xMax="10.0" yMin="0.0" width="230" display="Queue length over time">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="queue-len" color="-16777216" legend="true">
        <setup></setup>
        <update>plot count customers with [not being-served?]</update>
      </pen>
    </plot>
  </widgets>
