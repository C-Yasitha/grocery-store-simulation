    <monitor x="1125" precision="17" y="360" height="60" fontSize="11" width="175" display="Sim time (minutes)">ticks / 60</monitor>
    <monitor x="1125" precision="17" y="285" height="60" fontSize="11" width="175" display="Current queue length">count customers with [not being-served?]</monitor>
